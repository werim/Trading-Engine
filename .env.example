# =========================
# ENGINE
# =========================
EXECUTION_MODE=REAL
BASE_DIR=.
DATA_DIR=data
LOG_DIR=logs

# =========================
# BINANCE
# =========================
BINANCE_API_KEY=YOUR_BINANCE_API_KEY
BINANCE_API_SECRET=YOUR_BINANCE_API_SECRET
BINANCE_BASE_URL=https://fapi.binance.com
BINANCE_RECV_WINDOW=5000
BINANCE_TESTNET=0

# =========================
# TELEGRAM
# =========================
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# =========================
# MARKET UNIVERSE
# =========================
MAX_SYMBOLS=60

# =========================
# TIMEFRAMES
# =========================
HTF_INTERVAL=1d
MTF_INTERVAL=4h
LTF_INTERVAL=1h
MICRO_INTERVAL=15m
KLINE_LIMIT=240

# =========================
# INDICATORS
# =========================
EMA_FAST=20
EMA_MID=50
EMA_SLOW=200
ATR_PERIOD=14
SWING_LOOKBACK=8
BREAKOUT_LOOKBACK=20

# =========================
# FILTERS FOR BETTER NET_PNL_PCT
# =========================
SCORE_MIN=5
RR_MIN=2.2
RR_IDEAL=2.8
MIN_EXPECTED_NET_PNL_PCT=1.20

MIN_STOP_PCT=0.75
MAX_STOP_PCT=3.80
MIN_TP_PCT=1.80
MAX_TP_PCT=8.50

MIN_VOLUME_USDT_24H=5000000
MAX_SPREAD_PCT=0.20
MAX_FUNDING_ABS_PCT=0.08
SKIP_RANGE_DAILY=1

# =========================
# POSITION SIZING
# =========================
USDT_PER_TRADE=35
LEVERAGE=3
MAX_OPEN_POSITIONS=3

# =========================
# ORDER EXECUTION
# =========================
USE_LIMIT_ENTRY=1
ENTRY_BUFFER_BPS=4
SL_BUFFER_BPS=6
TP_BUFFER_BPS=6

# =========================
# COST MODEL
# =========================
MAKER_FEE_PCT=0.02
TAKER_FEE_PCT=0.05
ROUND_TRIP_SLIPPAGE_PCT=0.08

# =========================
# POSITION MANAGEMENT
# =========================
BREAK_EVEN_TRIGGER_R=1.0
TRAIL_AFTER_R=1.5
PARTIAL_TP_AT_R=1.2
PARTIAL_CLOSE_RATIO=0.40
ENABLE_TRAILING=1

# =========================
# LOOP INTERVALS
# =========================
ORDER_LOOP_SECONDS=300
POSITION_LOOP_SECONDS=4

# =========================
# ALERTS
# =========================
TELEGRAM_ALERTS=1
ORDER_ALERT=1